{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "redirector",
	"compatibility_date": "2025-08-03",
	"main": "./src/index.ts",
	"assets": {
		"directory": "../../dist",
		"binding": "ASSETS",
		"not_found_handling": "single-page-application",
		"run_worker_first": ["/api/*", "/r/*"]
	},
	"kv_namespaces": [
		{
			"binding": "REDIRECTS"
		}
	]
}
